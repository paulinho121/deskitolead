# API Keys para produção - Configure na Vercel Dashboard
# Settings → Environment Variables

# API Key do Serper para busca no Google Maps
# Obtenha em: https://serper.dev/
REACT_APP_SERPER_API_KEY=sua_chave_serper_aqui

# API Key do Google Gemini para enriquecimento de leads
# Obtenha em: https://aistudio.google.com/
GEMINI_API_KEY=sua_chave_gemini_aqui

# Configurações opcionais
NODE_ENV=production
VITE_API_BASE_URL=https://seu-projeto.vercel.app
