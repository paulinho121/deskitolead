# API Key do Serper para busca no Google Maps
# Substitua "SUA_API_KEY_AQUI" pela sua chave real da API Serper
REACT_APP_SERPER_API_KEY=SUA_API_KEY_AQUI

# Para obter uma API key:
# 1. Acesse https://serper.dev/
# 2. Crie uma conta gratuita
# 3. Copie sua API key do dashboard
# 4. Substitua no arquivo acima
